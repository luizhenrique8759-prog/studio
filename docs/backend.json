
{
  "entities": {
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "description": "Represents a user account with hierarchical authority levels (1: Reception, 2: Clinical, 3: Administrative).",
      "properties": {
        "id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "email": {
          "type": "string",
          "format": "email"
        },
        "phoneNumber": {
          "type": "string"
        },
        "role": {
          "type": "string",
          "description": "User role: 'patient' or 'professional'."
        },
        "authorityLevel": {
          "type": "number",
          "description": "1: Reception (Agenda), 2: Clinical (Records), 3: Admin (Finance/Team).",
          "enum": [1, 2, 3]
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "id",
        "name",
        "email",
        "role",
        "createdAt",
        "updatedAt"
      ]
    },
    "MedicalRecord": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "MedicalRecord",
      "type": "object",
      "description": "Clinical evolution and patient files.",
      "properties": {
        "id": { "type": "string" },
        "patientUserId": { "type": "string" },
        "professionalId": { "type": "string" },
        "notes": { "type": "string" },
        "treatment": { "type": "string" },
        "aiSummary": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": [ "id", "patientUserId", "notes", "createdAt" ]
    }
  },
  "auth": {
    "providers": [ "google" ]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "User",
          "schema": { "$ref": "#/backend/entities/User" },
          "description": "User profiles with authority levels."
        }
      },
      {
        "path": "/medical_records/{recordId}",
        "definition": {
          "entityName": "MedicalRecord",
          "schema": { "$ref": "#/backend/entities/MedicalRecord" },
          "description": "Restricted to Level 2 and above."
        }
      }
    ]
  }
}
