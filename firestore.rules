
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    // Administradores Mestre (Bypass prioritário por e-mail)
    function isMasterAdmin() {
      return isSignedIn() && (
        request.auth.token.email == "luizhenrique8759@gmail.com" ||
        request.auth.token.email == "luiz87596531@gmail.com"
      );
    }

    // Busca autoridade do documento do usuário
    function getAuthority() {
      let userDocPath = /databases/$(database)/documents/users/$(request.auth.uid);
      return exists(userDocPath) ? get(userDocPath).data.authorityLevel : 0;
    }

    function hasAdminPrivileges() {
      return isMasterAdmin() || (isSignedIn() && getAuthority() >= 3);
    }

    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if hasAdminPrivileges();
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if hasAdminPrivileges() || (isSignedIn() && request.auth.uid == userId);
    }

    match /appointments/{apptId} {
      // Permissão de listagem global para admins ou recepcionistas
      allow list: if isSignedIn() && (
        isMasterAdmin() || 
        getAuthority() >= 1
      );
      
      // Pacientes só listam com filtro de patientId no código (o que torna a regra de listagem segura)
      // Nota: O Firestore Rules não filtra, ele apenas valida a consulta.
      
      allow get: if isSignedIn() && (
        isMasterAdmin() || 
        getAuthority() >= 1 || 
        resource.data.patientId == request.auth.uid
      );
      
      allow create: if isSignedIn();
      
      allow update, delete: if isMasterAdmin() || (isSignedIn() && (
        getAuthority() >= 1 || 
        (resource != null && resource.data.patientId == request.auth.uid)
      ));
    }

    match /medical_records/{recordId} {
      allow read, write: if isMasterAdmin() || (isSignedIn() && (getAuthority() >= 2));
    }

    match /services/{id} { 
      allow read: if true; 
      allow write: if hasAdminPrivileges(); 
    }
  }
}
