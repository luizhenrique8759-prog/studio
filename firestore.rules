
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    // Função de administrador simplificada para máxima performance e confiabilidade
    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == "luizhenrique8759@gmail.com" ||
        exists(/databases/$(database)/documents/app_roles/admin/users/$(request.auth.uid))
      );
    }

    function isProfessional() {
      let userPath = /databases/$(database)/documents/users/$(request.auth.uid);
      return isAdmin() || (isSignedIn() && exists(userPath) && get(userPath).data.role in ['professional', 'admin']);
    }

    function getAuthorityLevel() {
      let userPath = /databases/$(database)/documents/users/$(request.auth.uid);
      return exists(userPath) ? get(userPath).data.get('authorityLevel', 0) : 0;
    }

    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isAdmin() || (isProfessional() && getAuthorityLevel() >= 1);
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isAdmin() || (isSignedIn() && request.auth.uid == userId);
    }

    match /medical_records/{recordId} {
      allow read, write: if isAdmin() || (isProfessional() && getAuthorityLevel() >= 2);
    }

    match /app_roles/{role}/users/{userId} {
      allow read: if isSignedIn();
      allow write: if isAdmin(); 
    }
    
    match /appointments/{id} { 
      // Permissões de Listagem: Admin e Profissionais autorizados podem ver tudo
      allow list: if isAdmin() || (isProfessional() && getAuthorityLevel() >= 1);
      
      // Pacientes vêem apenas seus próprios documentos (requer filtro .where('patientId', '==', uid))
      allow list: if isSignedIn() && request.auth.uid == resource.data.patientId;
      
      allow get: if isSignedIn() && (
        isAdmin() || 
        (isProfessional() && getAuthorityLevel() >= 1) || 
        request.auth.uid == resource.data.patientId
      );
      
      allow create: if isSignedIn();
      allow update, delete: if isAdmin() || (isProfessional() && getAuthorityLevel() >= 1);
    }
    
    match /services/{id} { allow read: if true; allow write: if isAdmin(); }
    match /professionals/{id} { allow read: if true; allow write: if isAdmin(); }
  }
}
