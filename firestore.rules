
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/app_roles/admin/$(request.auth.uid)) ||
        request.auth.token.email == "luizhenrique8759@gmail.com"
      );
    }

    function getAuthorityLevel() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.authorityLevel;
    }

    function isProfessional() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/app_roles/professional/$(request.auth.uid)) ||
        isAdmin()
      );
    }

    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isAdmin() || (isProfessional() && getAuthorityLevel() >= 3);
      allow create, update: if isSignedIn() && request.auth.uid == userId;
      allow update: if isAdmin();
    }

    match /medical_records/{recordId} {
      allow get, list, create: if isAdmin() || (isProfessional() && getAuthorityLevel() >= 2);
      allow update: if isAdmin() || (isProfessional() && getAuthorityLevel() >= 2 && resource.data.professionalId == request.auth.uid);
    }

    match /app_roles/{role}/{userId} {
      allow get: if isSignedIn();
      allow write: if isAdmin(); 
    }
    
    match /appointments/{id} { allow read, write: if isSignedIn(); }
    match /services/{id} { allow read: if true; allow write: if isAdmin(); }
    match /professionals/{id} { allow read: if true; allow write: if isAdmin(); }
  }
}
