
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Função para verificar se é o administrador mestre pelo e-mail do token
    function isMasterAdmin() {
      return request.auth != null && request.auth.token.email == "luizhenrique8759@gmail.com";
    }

    function isSignedIn() {
      return request.auth != null;
    }

    // Busca autoridade do usuário logado (usado para colaboradores)
    function getAuthority() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.authorityLevel;
    }

    // Regra Global Master Admin: Acesso total e absoluto
    match /{document=**} {
      allow read, write: if isMasterAdmin();
    }

    // Usuários
    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn() && (isMasterAdmin() || getAuthority() >= 3);
      allow create, update: if isSignedIn() && (request.auth.uid == userId || isMasterAdmin());
    }

    // Agendamentos (Appointments)
    match /appointments/{apptId} {
      // Permitir listagem total para Master Admin ou Colaboradores Nível 1+
      // Pacientes só podem listar se usarem o filtro de patientId no código
      allow list: if isSignedIn() && (
        isMasterAdmin() || 
        getAuthority() >= 1 || 
        (resource != null && resource.data.patientId == request.auth.uid)
      );
      
      allow get: if isSignedIn() && (
        isMasterAdmin() || 
        getAuthority() >= 1 || 
        (resource != null && resource.data.patientId == request.auth.uid)
      );
      
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && (isMasterAdmin() || getAuthority() >= 1);
    }

    // Prontuários Médicos
    match /medical_records/{recordId} {
      allow read, write: if isSignedIn() && (isMasterAdmin() || getAuthority() >= 2);
    }

    // Serviços e Coleções Gerais
    match /services/{id} { allow read: if true; allow write: if isMasterAdmin(); }
  }
}
