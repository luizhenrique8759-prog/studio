
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isMasterAdmin() {
      return isSignedIn() && (
        request.auth.token.email == "luizhenrique8759@gmail.com"
      );
    }

    function getAuthority() {
      let userDocPath = /databases/$(database)/documents/users/$(request.auth.uid);
      return exists(userDocPath) ? get(userDocPath).data.get('authorityLevel', 0) : 0;
    }

    function isStaff() {
      return isMasterAdmin() || (isSignedIn() && getAuthority() >= 1);
    }

    function isAdmin() {
      return isMasterAdmin() || (isSignedIn() && getAuthority() >= 3);
    }

    function isDentist() {
      return isMasterAdmin() || (isSignedIn() && getAuthority() >= 4);
    }

    match /users/{userId} {
      // Permite listagem se for staff ou se for uma busca limitada (como a de convite por email no login)
      allow list: if isStaff() || (isSignedIn() && request.query.limit <= 1);
      
      allow get: if isSignedIn() && (
        request.auth.uid == userId || 
        isStaff() || 
        (resource != null && resource.data.email == request.auth.token.email)
      );
      
      allow create: if isSignedIn(); 
      
      allow delete: if isMasterAdmin() || isAdmin();
      
      allow update: if isMasterAdmin() || isAdmin() || (isSignedIn() && request.auth.uid == userId);
    }

    match /appointments/{apptId} {
      allow read: if isStaff() || (isSignedIn() && resource.data.patientId == request.auth.uid);
      allow write: if isStaff();
    }

    match /medical_records/{recordId} {
      allow read: if isStaff();
      allow write: if isMasterAdmin() || isDentist();
    }

    match /services/{id} { 
      allow read: if isSignedIn(); 
      allow write: if isMasterAdmin() || isAdmin(); 
    }
  }
}
