
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    // Verificação de administradores mestres por e-mail (Bypass absoluto)
    function isMasterAdmin() {
      return isSignedIn() && (
        request.auth.token.email == "luizhenrique8759@gmail.com" || 
        request.auth.token.email == "luiz87596531@gmail.com"
      );
    }

    function getAuthority() {
      let userDocPath = /databases/$(database)/documents/users/$(request.auth.uid);
      return exists(userDocPath) ? get(userDocPath).data.get('authorityLevel', 0) : 0;
    }

    // Equipe: E-mails mestres ou qualquer um com nível 1 ou superior no banco
    function isStaff() {
      return isSignedIn() && (isMasterAdmin() || getAuthority() >= 1);
    }

    // Administrador: E-mails mestres ou nível 3 ou superior no banco
    function isAdmin() {
      return isSignedIn() && (isMasterAdmin() || getAuthority() >= 3);
    }

    // Dentista: Nível 4 ou superior
    function isDentist() {
      return isSignedIn() && (isMasterAdmin() || getAuthority() >= 4);
    }

    // Coleção de usuários
    match /users/{userId} {
      allow list: if isStaff();
      allow get: if isSignedIn();
      allow create: if isSignedIn(); 
      allow update: if isAdmin() || (isSignedIn() && request.auth.uid == userId);
    }

    // Agendamentos: Exclusivo para equipe
    match /appointments/{apptId} {
      allow read, write: if isStaff();
    }

    // Prontuários: Leitura para toda a equipe, escrita apenas para Dentista ou Master Admin
    match /medical_records/{recordId} {
      allow read: if isStaff();
      allow write: if isMasterAdmin() || isDentist();
    }

    match /services/{id} { 
      allow read: if isSignedIn(); 
      allow write: if isAdmin(); 
    }
  }
}
