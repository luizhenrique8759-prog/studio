
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == "luizhenrique8759@gmail.com" ||
        exists(/databases/$(database)/documents/app_roles/admin/users/$(request.auth.uid))
      );
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function getAuthorityLevel() {
      let userPath = /databases/$(database)/documents/users/$(request.auth.uid);
      return exists(userPath) ? getUserData().get('authorityLevel', 0) : 0;
    }

    function isProfessional() {
      let userPath = /databases/$(database)/documents/users/$(request.auth.uid);
      return isAdmin() || (isSignedIn() && (
        exists(/databases/$(database)/documents/app_roles/professional/users/$(request.auth.uid)) ||
        (exists(userPath) && getUserData().get('role', '') == 'professional')
      ));
    }

    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isAdmin() || (isProfessional() && getAuthorityLevel() >= 1);
      allow create, update: if isSignedIn() && request.auth.uid == userId;
      allow update: if isAdmin();
    }

    match /medical_records/{recordId} {
      allow read, write: if isAdmin() || (isProfessional() && getAuthorityLevel() >= 2);
    }

    match /app_roles/{role}/users/{userId} {
      allow read: if isSignedIn();
      allow write: if isAdmin(); 
    }
    
    match /appointments/{id} { 
      // Separação de list e get para maior robustez em consultas globais
      allow list: if isSignedIn() && (
        isAdmin() || 
        (isProfessional() && getAuthorityLevel() >= 1) || 
        request.auth.uid == resource.data.patientId
      );
      
      allow get: if isSignedIn() && (
        isAdmin() || 
        (isProfessional() && getAuthorityLevel() >= 1) || 
        request.auth.uid == resource.data.patientId
      );
      
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && (isAdmin() || (isProfessional() && getAuthorityLevel() >= 1));
    }
    
    match /services/{id} { allow read: if true; allow write: if isAdmin(); }
    match /professionals/{id} { allow read: if true; allow write: if isAdmin(); }
  }
}
