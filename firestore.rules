
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    // Busca autoridade do usuário logado de forma segura
    function getAuthority() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.authorityLevel;
    }

    // Usuários: Próprio usuário ou Administradores (Nível 3+)
    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn() && getAuthority() >= 3;
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isSignedIn() && (request.auth.uid == userId || getAuthority() >= 3);
    }

    // Agendamentos (Appointments)
    match /appointments/{apptId} {
      // Regra de listagem: Colaboradores (1+) ou se for o dono (paciente)
      // O Firestore exige que a consulta no código tenha o filtro 'where patientId == uid' para pacientes
      allow list: if isSignedIn() && (
        getAuthority() >= 1 || 
        resource.data.patientId == request.auth.uid
      );
      
      allow get: if isSignedIn() && (
        getAuthority() >= 1 || 
        resource.data.patientId == request.auth.uid
      );
      
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && (getAuthority() >= 1 || resource.data.patientId == request.auth.uid);
    }

    // Prontuários Médicos: Apenas Nível 2 (Assistente/Dentista) e acima
    match /medical_records/{recordId} {
      allow read, write: if isSignedIn() && getAuthority() >= 2;
    }

    // Serviços: Público para leitura, Administrador (3+) para escrita
    match /services/{id} { 
      allow read: if true; 
      allow write: if isSignedIn() && getAuthority() >= 3; 
    }
  }
}
