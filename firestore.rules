
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function getAuthority() {
      let userDocPath = /databases/$(database)/documents/users/$(request.auth.uid);
      return exists(userDocPath) ? get(userDocPath).data.authorityLevel : 0;
    }

    function isStaff() {
      return isSignedIn() && (
        request.auth.token.email == "luizhenrique8759@gmail.com" || 
        request.auth.token.email == "luiz87596531@gmail.com" ||
        getAuthority() >= 1
      );
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == "luizhenrique8759@gmail.com" || 
        request.auth.token.email == "luiz87596531@gmail.com" ||
        getAuthority() >= 3
      );
    }

    match /users/{userId} {
      allow list: if isStaff();
      allow get: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isStaff() || (isSignedIn() && request.auth.uid == userId);
    }

    match /appointments/{apptId} {
      allow read, write: if isStaff();
    }

    match /medical_records/{recordId} {
      allow read, write: if isStaff() && (getAuthority() >= 2 || isAdmin());
    }

    match /services/{id} { 
      allow read: if true; 
      allow write: if isAdmin(); 
    }
  }
}
