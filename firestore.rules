
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Função Master Admin: Prioridade absoluta baseada no e-mail blindado
    function isMasterAdmin() {
      return request.auth != null && request.auth.token.email == "luizhenrique8759@gmail.com";
    }

    function isSignedIn() {
      return request.auth != null;
    }

    // Verifica nível de autoridade buscando o documento do usuário
    // Usamos get() de forma segura
    function getAuthority() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('authorityLevel', 0);
    }

    // Regra Global Master: Se for o admin mestre, permite tudo imediatamente
    match /{document=**} {
      allow read, write: if isMasterAdmin();
    }

    // Coleção de Usuários
    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isMasterAdmin() || (isSignedIn() && getAuthority() >= 3);
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isMasterAdmin() || (isSignedIn() && request.auth.uid == userId);
    }

    // Agendamentos
    match /appointments/{apptId} { 
      // Permite listagem global para profissionais Nível 1+ ou Admin
      allow list: if isMasterAdmin() || (isSignedIn() && getAuthority() >= 1);
      
      // Permite listagem filtrada para pacientes (deve usar where 'patientId' == uid)
      allow list: if isSignedIn() && resource.data.patientId == request.auth.uid;
      
      allow get: if isSignedIn() && (
        isMasterAdmin() || 
        getAuthority() >= 1 || 
        resource.data.patientId == request.auth.uid
      );
      
      allow create: if isSignedIn();
      allow update, delete: if isMasterAdmin() || (isSignedIn() && getAuthority() >= 1);
    }

    // Prontuários Médicos: Nível 2 ou 4 (Clínico) ou Nível 3 (Admin)
    match /medical_records/{recordId} {
      allow read, write: if isMasterAdmin() || (isSignedIn() && (getAuthority() >= 2 || getAuthority() == 4));
    }

    // Coleções Auxiliares
    match /services/{id} { allow read: if true; allow write: if isMasterAdmin(); }
    match /app_roles/{document=**} { allow read, write: if isMasterAdmin(); }
  }
}
