rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    // Administrador "Blindado": Verifica documento ou e-mail específico
    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/app_roles/admin/$(request.auth.uid)) ||
        request.auth.token.email == "luizhenrique8759@gmail.com"
      );
    }

    function isProfessional() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/app_roles/professional/$(request.auth.uid)) ||
        isAdmin() // Admins também têm permissão de profissional
      );
    }

    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isAdmin() || isProfessional();
      allow create, update: if isSignedIn() && request.auth.uid == userId;
    }

    match /medical_records/{recordId} {
      allow get: if isAdmin() || isProfessional() || (isSignedIn() && resource.data.patientUserId == request.auth.uid);
      allow list: if isAdmin() || isProfessional();
      allow create: if isAdmin() || isProfessional();
      allow update: if isAdmin() || (isProfessional() && resource.data.professionalId == request.auth.uid);
    }

    match /app_roles/{role}/{userId} {
      allow get: if isSignedIn();
      allow write: if false; 
    }
    
    match /appointments/{id} { allow read, write: if isSignedIn(); }
    match /services/{id} { allow read: if true; allow write: if isAdmin(); }
    match /professionals/{id} { allow read: if true; allow write: if isAdmin(); }
  }
}
