
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Função Master Admin: Prioridade absoluta e imediata
    function isMasterAdmin() {
      return request.auth != null && request.auth.token.email == "luizhenrique8759@gmail.com";
    }

    function isSignedIn() {
      return request.auth != null;
    }

    // Verifica nível de autoridade no documento do usuário
    function hasAuthority(level) {
      let userDoc = get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
      return userDoc.get('authorityLevel', 0) >= level;
    }

    // Verifica se é profissional (Nível 1+)
    function isProfessional() {
      return isSignedIn() && (
        isMasterAdmin() || 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', 'patient') in ['professional', 'admin']
      );
    }

    // Regra Global de Emergência para o Administrador Master
    // Isso garante acesso total antes de qualquer outra regra ser avaliada
    match /{document=**} {
      allow read, write: if isMasterAdmin();
    }

    // Coleção de Usuários
    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isMasterAdmin() || (isProfessional() && hasAuthority(3));
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isMasterAdmin() || (isSignedIn() && request.auth.uid == userId);
    }

    // Prontuários Médicos: Nível 2+ ou Master Admin
    match /medical_records/{recordId} {
      allow read, write: if isMasterAdmin() || (isProfessional() && hasAuthority(2));
    }

    // Agendamentos: Separação clara de Admin e Paciente
    match /appointments/{id} { 
      // Permissão para Administradores e Recepção listar tudo
      allow list: if isMasterAdmin() || (isProfessional() && hasAuthority(1));
      
      // Permissão para Paciente listar apenas seus agendamentos
      // Nota: O paciente DEVE usar um filtro .where('patientId', '==', uid) na query
      allow list: if isSignedIn() && resource.data.patientId == request.auth.uid;
      
      allow get: if isSignedIn() && (
        isMasterAdmin() || 
        (isProfessional() && hasAuthority(1)) || 
        resource.data.patientId == request.auth.uid
      );
      
      allow create: if isSignedIn();
      allow update, delete: if isMasterAdmin() || (isProfessional() && hasAuthority(1));
    }

    // Coleções Auxiliares
    match /app_roles/{role}/users/{userId} {
      allow read: if isSignedIn();
      allow write: if isMasterAdmin(); 
    }
    
    match /services/{id} { allow read: if true; allow write: if isMasterAdmin(); }
    match /professionals/{id} { allow read: if true; allow write: if isMasterAdmin(); }
  }
}
