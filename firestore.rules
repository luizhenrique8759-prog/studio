
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    // Busca autoridade do documento do usuário de forma segura
    function getAuthority() {
      let userDocPath = /databases/$(database)/documents/users/$(request.auth.uid);
      return exists(userDocPath) ? get(userDocPath).data.authorityLevel : 0;
    }

    function hasAdminPrivileges() {
      return isSignedIn() && getAuthority() >= 3;
    }

    function hasStaffPrivileges() {
      return isSignedIn() && getAuthority() >= 1;
    }

    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if hasAdminPrivileges();
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if hasAdminPrivileges() || (isSignedIn() && request.auth.uid == userId);
    }

    match /appointments/{apptId} {
      allow list: if isSignedIn() && (
        hasStaffPrivileges() || 
        (resource != null && resource.data.patientId == request.auth.uid) ||
        (request.query.limit <= 100 && request.query.filters.size() > 0) // Permite consultas filtradas no dashboard
      );
      
      allow get: if isSignedIn() && (
        hasStaffPrivileges() || 
        resource.data.patientId == request.auth.uid
      );
      
      allow create: if isSignedIn();
      
      allow update, delete: if isSignedIn() && (
        hasStaffPrivileges() || 
        (resource != null && resource.data.patientId == request.auth.uid)
      );
    }

    match /medical_records/{recordId} {
      allow read, write: if isSignedIn() && getAuthority() >= 2;
    }

    match /services/{id} { 
      allow read: if true; 
      allow write: if hasAdminPrivileges(); 
    }
  }
}
