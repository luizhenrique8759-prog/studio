
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Função de segurança máxima para o administrador mestre
    function isMasterAdmin() {
      return request.auth != null && request.auth.token.email == "luizhenrique8759@gmail.com";
    }

    function isSignedIn() {
      return request.auth != null;
    }

    // Busca autoridade do documento de usuário de forma segura
    function getAuthority() {
      let userDoc = get(/databases/$(database)/documents/users/$(request.auth.uid));
      return userDoc != null ? userDoc.data.get('authorityLevel', 0) : 0;
    }

    // Regra Global Master: Se for o admin mestre, permite tudo imediatamente
    match /{document=**} {
      allow read, write: if isMasterAdmin();
    }

    // Coleção de Usuários
    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isMasterAdmin() || (isSignedIn() && getAuthority() >= 3);
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isMasterAdmin() || (isSignedIn() && request.auth.uid == userId);
    }

    // Agendamentos
    match /appointments/{apptId} { 
      // Permite listagem global para staff ou listagem filtrada para o próprio paciente
      allow list: if isSignedIn() && (
        isMasterAdmin() || 
        getAuthority() >= 1 || 
        resource.data.patientId == request.auth.uid
      );
      
      allow get: if isSignedIn() && (
        isMasterAdmin() || 
        getAuthority() >= 1 || 
        resource.data.patientId == request.auth.uid
      );
      
      allow create: if isSignedIn();
      allow update, delete: if isMasterAdmin() || (isSignedIn() && getAuthority() >= 1);
    }

    // Prontuários Médicos
    match /medical_records/{recordId} {
      allow read, write: if isMasterAdmin() || (isSignedIn() && getAuthority() >= 2);
    }

    // Coleções Auxiliares
    match /services/{id} { allow read: if true; allow write: if isMasterAdmin(); }
    match /app_roles/{document=**} { allow read, write: if isMasterAdmin(); }
  }
}
