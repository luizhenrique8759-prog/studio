
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isMasterAdmin() {
      return isSignedIn() && (
        request.auth.token.email == "luizhenrique8759@gmail.com" || 
        request.auth.token.email == "luiz87596531@gmail.com"
      );
    }

    function getAuthority() {
      let userDocPath = /databases/$(database)/documents/users/$(request.auth.uid);
      return exists(userDocPath) ? get(userDocPath).data.get('authorityLevel', 0) : 0;
    }

    function isStaff() {
      return isMasterAdmin() || (isSignedIn() && getAuthority() >= 1);
    }

    function isAdmin() {
      return isMasterAdmin() || (isSignedIn() && getAuthority() >= 3);
    }

    function isDentist() {
      return isMasterAdmin() || (isSignedIn() && getAuthority() >= 4);
    }

    match /users/{userId} {
      // Permite listagem se for equipe OU se o usuário estiver procurando pelo seu próprio e-mail (migração de login)
      allow list: if isStaff() || (isSignedIn() && request.query.limit <= 1);
      
      // Permite get se for o próprio documento, se for equipe, ou se o e-mail coincidir (segurança para o fluxo de login)
      allow get: if isSignedIn() && (
        request.auth.uid == userId || 
        isStaff() || 
        (resource != null && resource.data.email == request.auth.token.email)
      );
      
      allow create: if isSignedIn(); 
      
      // Permite deleção do doc temporário se o e-mail coincidir
      allow delete: if isAdmin() || (isSignedIn() && resource.data.email == request.auth.token.email);
      
      allow update: if isAdmin() || (isSignedIn() && request.auth.uid == userId);
    }

    match /appointments/{apptId} {
      allow read, write: if isStaff();
    }

    match /medical_records/{recordId} {
      allow read: if isStaff();
      allow write: if isMasterAdmin() || isDentist();
    }

    match /services/{id} { 
      allow read: if isSignedIn(); 
      allow write: if isAdmin(); 
    }
  }
}
