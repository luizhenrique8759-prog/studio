
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Função Master Admin: Prioridade máxima baseada no e-mail tokenizado
    function isMasterAdmin() {
      return request.auth != null && request.auth.token.email == "luizhenrique8759@gmail.com";
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function getAuthorityLevel() {
      let userPath = /databases/$(database)/documents/users/$(request.auth.uid);
      return exists(userPath) ? get(userPath).data.get('authorityLevel', 0) : 0;
    }

    function isProfessional() {
      let userPath = /databases/$(database)/documents/users/$(request.auth.uid);
      return isSignedIn() && (
        isMasterAdmin() || 
        (exists(userPath) && get(userPath).data.get('role', 'patient') in ['professional', 'admin'])
      );
    }

    // Regra Global de Segurança para o Administrador Master
    match /{document=**} {
      allow read, write: if isMasterAdmin();
    }

    // Coleção de Usuários
    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isMasterAdmin() || (isProfessional() && getAuthorityLevel() >= 3);
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isMasterAdmin() || (isSignedIn() && request.auth.uid == userId);
    }

    // Prontuários Médicos: Nível 2+
    match /medical_records/{recordId} {
      allow read, write: if isMasterAdmin() || (isProfessional() && getAuthorityLevel() >= 2);
    }

    // Agendamentos: Sincronização e Filtros
    match /appointments/{id} { 
      // Permissões Administrativas (Listagem irrestrita)
      allow list: if isMasterAdmin() || (isProfessional() && getAuthorityLevel() >= 1);
      
      // Permissões de Paciente (Necessita filtro no cliente para listagem)
      allow list: if isSignedIn() && resource.data.patientId == request.auth.uid;
      
      allow get: if isSignedIn() && (
        isMasterAdmin() || 
        (isProfessional() && getAuthorityLevel() >= 1) || 
        resource.data.patientId == request.auth.uid
      );
      
      allow create: if isSignedIn();
      allow update, delete: if isMasterAdmin() || (isProfessional() && getAuthorityLevel() >= 1);
    }

    // Coleções Auxiliares
    match /app_roles/{role}/users/{userId} {
      allow read: if isSignedIn();
      allow write: if isMasterAdmin(); 
    }
    
    match /services/{id} { allow read: if true; allow write: if isMasterAdmin(); }
    match /professionals/{id} { allow read: if true; allow write: if isMasterAdmin(); }
  }
}
