
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ADMIN MESTRE: Acesso absoluto via e-mail do token (mais seguro e rápido)
    function isMasterAdmin() {
      return request.auth != null && request.auth.token.email == "luizhenrique8759@gmail.com";
    }

    function isSignedIn() {
      return request.auth != null;
    }

    // Busca autoridade do usuário logado
    function getAuthority() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.authorityLevel;
    }

    // Regra Global Master Admin
    match /{document=**} {
      allow read, write: if isMasterAdmin();
    }

    // Usuários
    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn() && (isMasterAdmin() || getAuthority() >= 3);
      allow create, update: if isSignedIn() && request.auth.uid == userId;
    }

    // Agendamentos (Appointments)
    match /appointments/{apptId} {
      // Regra para listagem: Profissionais ou o próprio paciente (com filtro obrigatório)
      allow list: if isSignedIn() && (
        isMasterAdmin() || 
        getAuthority() >= 1 || 
        resource.data.patientId == request.auth.uid
      );
      
      // Regra para leitura individual
      allow get: if isSignedIn() && (
        isMasterAdmin() || 
        getAuthority() >= 1 || 
        resource.data.patientId == request.auth.uid
      );
      
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && (isMasterAdmin() || getAuthority() >= 1);
    }

    // Prontuários Médicos
    match /medical_records/{recordId} {
      allow read, write: if isSignedIn() && (isMasterAdmin() || getAuthority() >= 2);
    }

    // Coleções Gerais
    match /services/{id} { allow read: if true; allow write: if isMasterAdmin(); }
  }
}
