
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isMasterAdmin() {
      return isSignedIn() && (
        request.auth.token.email == "luizhenrique8759@gmail.com" || 
        request.auth.token.email == "luiz87596531@gmail.com"
      );
    }

    function getAuthority() {
      let userDocPath = /databases/$(database)/documents/users/$(request.auth.uid);
      return exists(userDocPath) ? get(userDocPath).data.get('authorityLevel', 0) : 0;
    }

    function isStaff() {
      return isMasterAdmin() || (isSignedIn() && getAuthority() >= 1);
    }

    function isAdmin() {
      return isMasterAdmin() || (isSignedIn() && getAuthority() >= 3);
    }

    function isDentist() {
      return isMasterAdmin() || (isSignedIn() && getAuthority() >= 4);
    }

    match /users/{userId} {
      allow list: if isStaff();
      allow get: if isSignedIn();
      allow create: if isSignedIn(); // Permitido para o primeiro login ou admin pré-cadastrar
      allow update, delete: if isAdmin() || (isSignedIn() && request.auth.uid == userId);
    }

    match /appointments/{apptId} {
      allow read, write: if isStaff();
    }

    match /medical_records/{recordId} {
      allow read: if isStaff();
      allow write: if isMasterAdmin() || isDentist();
    }

    match /services/{id} { 
      allow read: if isSignedIn(); 
      allow write: if isAdmin(); 
    }
  }
}
