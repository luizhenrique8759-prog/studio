
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isMasterAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'luizhenrique8759@gmail.com' ||
        request.auth.token.email == 'luiz88955548@gmail.com'
      );
    }

    function getAuthority() {
      let userDocPath = /databases/$(database)/documents/users/$(request.auth.uid);
      return exists(userDocPath) ? get(userDocPath).data.get('authorityLevel', 0) : 0;
    }

    function isStaff() {
      return isMasterAdmin() || (isSignedIn() && getAuthority() >= 1);
    }

    function isAdmin() {
      return isMasterAdmin() || (isSignedIn() && getAuthority() >= 3);
    }

    function isDentist() {
      return isMasterAdmin() || (isSignedIn() && getAuthority() >= 4);
    }

    match /users/{userId} {
      allow list: if isStaff();
      
      allow get: if isSignedIn() && (
        request.auth.uid == userId || 
        isStaff()
      );
      
      allow create: if isSignedIn(); 
      
      allow delete: if isStaff();
      
      allow update: if isAdmin() || (isSignedIn() && request.auth.uid == userId);
    }

    match /appointments/{apptId} {
      allow list: if isStaff();
      allow get: if isStaff() || (isSignedIn() && resource.data.patientId == request.auth.uid);
      allow write: if isStaff();
    }

    match /medical_records/{recordId} {
      allow list: if isStaff();
      allow get: if isStaff();
      allow create: if isStaff();
      allow update, delete: if isMasterAdmin() || isDentist();
    }

    match /services/{id} { 
      allow read: if isSignedIn(); 
      allow write: if isAdmin(); 
    }
  }
}
