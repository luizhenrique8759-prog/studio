
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    // Administradores Mestre
    function isMasterAdmin() {
      return isSignedIn() && (
        request.auth.token.email == "luizhenrique8759@gmail.com" ||
        request.auth.token.email == "luiz87596531@gmail.com"
      );
    }

    // Busca autoridade de forma segura (padrão 0 se não existir)
    function getAuthority() {
      let userDoc = /databases/$(database)/documents/users/$(request.auth.uid);
      return exists(userDoc) ? get(userDoc).data.authorityLevel : 0;
    }

    function hasAdminPrivileges() {
      return isMasterAdmin() || (isSignedIn() && getAuthority() >= 3);
    }

    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if hasAdminPrivileges();
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if hasAdminPrivileges() || (isSignedIn() && request.auth.uid == userId);
    }

    match /appointments/{apptId} {
      // Listagem: Admin vê tudo, Recepcionista vê tudo, Paciente vê apenas os seus
      allow list: if isSignedIn() && (
        hasAdminPrivileges() || 
        getAuthority() >= 1 || 
        (resource != null && resource.data.patientId == request.auth.uid) ||
        (resource == null) // Permite que a query seja avaliada com filtros
      );
      
      allow get: if isSignedIn() && (
        hasAdminPrivileges() || 
        getAuthority() >= 1 || 
        resource.data.patientId == request.auth.uid
      );
      
      // Criação: Qualquer um logado pode criar seu agendamento
      allow create: if isSignedIn();
      
      allow update, delete: if hasAdminPrivileges() || (isSignedIn() && (
        getAuthority() >= 1 || 
        resource.data.patientId == request.auth.uid
      ));
    }

    match /medical_records/{recordId} {
      allow read, write: if hasAdminPrivileges() || (isSignedIn() && (getAuthority() == 2 || getAuthority() == 4));
    }

    match /services/{id} { 
      allow read: if true; 
      allow write: if hasAdminPrivileges(); 
    }
  }
}
