
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isMasterAdmin() {
      return isSignedIn() && request.auth.token.email == "luizhenrique8759@gmail.com";
    }

    // Busca autoridade de forma segura (retorna 0 se não encontrar)
    function getAuthority() {
      let userDoc = get(/databases/$(database)/documents/users/$(request.auth.uid));
      return userDoc != null ? userDoc.data.get('authorityLevel', 0) : 0;
    }

    // Regra Global Master: Se for o admin mestre, permite tudo imediatamente
    match /{document=**} {
      allow read, write: if isMasterAdmin();
    }

    // Coleção de Usuários
    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isMasterAdmin() || (isSignedIn() && getAuthority() >= 3);
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isMasterAdmin() || (isSignedIn() && request.auth.uid == userId);
    }

    // Agendamentos
    match /appointments/{apptId} { 
      // Permite listagem se for Admin/Colaborador OU se a consulta for filtrada pelo ID do paciente
      allow list: if isSignedIn() && (
        isMasterAdmin() || 
        getAuthority() >= 1 || 
        (resource == null) // Permite iniciar a avaliação da consulta filtrada
      );
      
      // Regra de segurança em nível de documento para listagem filtrada
      allow read: if isSignedIn() && (
        isMasterAdmin() || 
        getAuthority() >= 1 || 
        resource.data.patientId == request.auth.uid
      );
      
      allow create: if isSignedIn();
      allow update, delete: if isMasterAdmin() || (isSignedIn() && getAuthority() >= 1);
    }

    // Prontuários Médicos
    match /medical_records/{recordId} {
      allow read, write: if isMasterAdmin() || (isSignedIn() && (getAuthority() >= 2 || getAuthority() == 4));
    }

    // Coleções Auxiliares
    match /services/{id} { allow read: if true; allow write: if isMasterAdmin(); }
    match /app_roles/{document=**} { allow read, write: if isMasterAdmin(); }
  }
}
