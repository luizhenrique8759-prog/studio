
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    // Administrador Mestre (Acesso Root)
    function isMasterAdmin() {
      return isSignedIn() && request.auth.token.email == "luizhenrique8759@gmail.com";
    }

    // Busca autoridade do usuário logado no documento
    function getAuthority() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.authorityLevel;
    }

    // Usuários: Próprio ou Administradores (Nível 3+)
    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isMasterAdmin() || (isSignedIn() && getAuthority() >= 3);
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isMasterAdmin() || (isSignedIn() && (request.auth.uid == userId || getAuthority() >= 3));
    }

    // Agendamentos (Appointments)
    match /appointments/{apptId} {
      allow list: if isMasterAdmin() || (isSignedIn() && (
        getAuthority() >= 1 || 
        resource.data.patientId == request.auth.uid
      ));
      
      allow get: if isMasterAdmin() || (isSignedIn() && (
        getAuthority() >= 1 || 
        resource.data.patientId == request.auth.uid
      ));
      
      allow create: if isSignedIn();
      allow update, delete: if isMasterAdmin() || (isSignedIn() && (
        getAuthority() >= 1 || 
        resource.data.patientId == request.auth.uid
      ));
    }

    // Prontuários Médicos: Nível 2 (Auxiliar), Nível 4 (Dentista) ou Master
    match /medical_records/{recordId} {
      allow read, write: if isMasterAdmin() || (isSignedIn() && (getAuthority() == 2 || getAuthority() == 4 || getAuthority() == 3));
    }

    // Serviços: Público leitura, Admin escrita
    match /services/{id} { 
      allow read: if true; 
      allow write: if isMasterAdmin() || (isSignedIn() && getAuthority() >= 3); 
    }
  }
}
