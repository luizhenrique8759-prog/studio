
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // PRIORIDADE ABSOLUTA: Master Admin (Acesso Total)
    // Usamos uma lista direta para evitar falhas de regex em tokens específicos
    function isMasterAdmin() {
      return request.auth != null && (
        request.auth.token.email == 'luizhenrique8759@gmail.com' ||
        request.auth.token.email == 'luiz88955548@gmail.com'
      );
    }

    // Regra Global de Bypass para Master Admins
    match /{document=**} {
      allow read, write: if isMasterAdmin();
    }

    // Funções auxiliares para outros níveis de acesso
    function isSignedIn() {
      return request.auth != null;
    }

    function getAuthority() {
      // Tenta obter o nível de autoridade do documento do usuário atual
      // Se o documento não existir, retorna 0 (acesso básico/paciente)
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('authorityLevel', 0);
    }

    function isStaff() {
      return isSignedIn() && (isMasterAdmin() || getAuthority() >= 1);
    }

    function isAssistant() {
      return isSignedIn() && (isMasterAdmin() || getAuthority() >= 2);
    }

    function isAdmin() {
      return isSignedIn() && (isMasterAdmin() || getAuthority() >= 3);
    }

    function isDentist() {
      return isSignedIn() && (isMasterAdmin() || getAuthority() >= 4);
    }

    // Regras Específicas por Coleção
    match /users/{userId} {
      // ESSENCIAL: Permitir listagem para encontrar convites pendentes por e-mail no login
      allow list: if isSignedIn();
      allow get: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isAdmin() || (isSignedIn() && request.auth.uid == userId);
      // Usuários podem deletar seus próprios registros (ex: limpar convite após login) ou Admin
      allow delete: if isMasterAdmin() || (isSignedIn() && (request.auth.uid == userId || resource.data.email == request.auth.token.email));
    }

    match /appointments/{apptId} {
      allow read: if isStaff() || (isSignedIn() && resource.data.patientId == request.auth.uid);
      allow write: if isStaff();
    }

    match /medical_records/{recordId} {
      allow read: if isStaff();
      allow create: if isAssistant() || isDentist();
      allow update, delete: if isDentist() || isMasterAdmin();
    }

    match /services/{id} { 
      allow read: if isSignedIn(); 
      allow write: if isAdmin(); 
    }
  }
}
